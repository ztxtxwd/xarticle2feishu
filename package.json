{
  "name": "xarticle2feishu",
  "version": "0.1.1",
  "description": "Generate a Feishu document from an x.com article URL via a remote MCP server.",
  "type": "module",
  "author": "赵天雄",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit -p tsconfig.json",
    "prepack": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ztxtxwd/xarticle2feishu.git"
  },
  "homepage": "https://github.com/ztxtxwd/xarticle2feishu#readme",
  "bugs": {
    "url": "https://github.com/ztxtxwd/xarticle2feishu/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "x.com",
    "twitter",
    "feishu",
    "mcp"
  ],
  "license": "MIT",
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/client": "^2.0.0-alpha.2"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
